---
import { Image } from 'astro:assets'
import type { MarkdownHeading } from 'astro'

// Plugin styles
import 'katex/dist/katex.min.css'

import { MediumZoom } from 'astro-pure/advanced'
import { Copyright, ArticleBottom, TOC } from 'astro-pure/components/pages'
import { FormattedDate, Icon } from 'astro-pure/user'
import { Comment, PageInfo } from '@/components/waline'
import config from 'virtual:config'
import PageLayout from '@/layouts/ContentLayout.astro'

// 禁止预渲染，确保每次请求都在服务端验证身份
export const prerender = false

import { isAuthenticated, getPrivateSlug } from '@/utils/auth'

// 未认证 → 重定向到密码页
if (!isAuthenticated(Astro.request)) {
  return Astro.redirect('/private')
}

// ============ 加载对应文章 ============
interface PostFrontmatter {
  title: string
  description?: string
  publishDate: string
  tags?: string[]
  language?: string
  heroImage?: { src: string; color?: string; alt?: string }
  draft?: boolean
  comment?: boolean
  updatedDate?: string
}

interface PostModule {
  frontmatter: PostFrontmatter
  Content: any
  getHeadings: () => MarkdownHeading[]
  rawContent: () => string
}

const { slug } = Astro.params

const postModules = import.meta.glob<PostModule>('/src/private-posts/**/[!_]*.md', { eager: true })
const entry = Object.entries(postModules).find(([path]) => getPrivateSlug(path) === slug)

if (!entry) {
  return Astro.redirect('/private')
}

const [, mod] = entry
const { frontmatter, Content } = mod
const headings = mod.getHeadings ? mod.getHeadings() : []

// ============ 解析题图 (heroImage) ============
let resolvedHeroImage: ImageMetadata | undefined
if (frontmatter.heroImage?.src) {
  const imageModules = import.meta.glob<{ default: ImageMetadata }>('/src/private-posts/**/*.{jpeg,jpg,png,gif,webp}')
  let src = frontmatter.heroImage.src
  if (src.startsWith('./') || src.startsWith('../')) {
    const dir = entry[0].split('/').slice(0, -1).join('/')
    if (src.startsWith('./')) src = src.slice(2)
    const absoluteImagePath = `${dir}/${src}`
    if (imageModules[absoluteImagePath]) {
      resolvedHeroImage = (await imageModules[absoluteImagePath]()).default
    }
  }
}

// ============ 获取其他文章用于 Bottom 和 阅读时间 ============
const rawContent = mod.rawContent ? mod.rawContent() : ''
const wordCount = rawContent.replace(/<[^>]*>/g, '').replace(/\s+/g, '').length
const minutesRead = Math.max(1, Math.ceil(wordCount / 300))

const allPostsForBottom = Object.entries(postModules).map(([path, m]) => {
  const s = getPrivateSlug(path)
  return {
    id: s,
    data: {
      ...m.frontmatter,
      title: m.frontmatter.title || s,
      publishDate: new Date(m.frontmatter.publishDate)
    }
  } as any
}).sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())

const dateTimeOptions: Intl.DateTimeFormatOptions = {
  month: 'short'
}
---

<PageLayout meta={{ title: frontmatter.title }} back='/private'>
  {!!headings.length && <TOC {headings} slot='sidebar' />}

  <Fragment slot='header'>
    {resolvedHeroImage && (
      <div class='hero-image relative mb-6'>
        <Image
          alt={frontmatter.title}
          class='cover-image relative z-10 h-auto w-full max-w-[65ch] rounded-2xl object-contain'
          fetchpriority='high'
          loading='eager'
          src={resolvedHeroImage}
        />
        <Image
          alt='Blur image'
          fetchpriority='high'
          loading='eager'
          id='blurImage'
          class='absolute end-0 top-4 z-0 mt-0 h-full max-w-[65ch] rounded-3xl opacity-60 transition-opacity duration-300'
          src={resolvedHeroImage}
        />
      </div>
    )}

    {frontmatter.draft ? <span class='text-red-500'>(Draft)</span> : null}

    <div class='article-info max-lg:mx-auto'>
      <div class='flex flex-wrap gap-x-4 gap-y-2 text-xs leading-6 text-muted-foreground'>
        <div class="flex items-center gap-1">
          <span class="px-1.5 py-0.5 rounded-md bg-primary text-primary-foreground text-[10px] font-bold tracking-wider relative -top-[1px]">🔒 私密</span>
        </div>
        <div class='flex items-center gap-1'>
          <Icon name='calendar' class='size-5' />
          <FormattedDate class='font-sans' date={new Date(frontmatter.publishDate)} dateTimeOptions={dateTimeOptions} />
          {
            frontmatter.updatedDate && (
              <div class='flex items-center gap-1'>
                <span> / </span>
                <span>
                  Update
                  <FormattedDate
                    class='font-sans'
                    date={new Date(frontmatter.updatedDate)}
                    dateTimeOptions={dateTimeOptions}
                  />
                </span>
              </div>
            )
          }
        </div>
        <div class='flex items-center gap-1'>
          <Icon name='time' class='size-5' />
          {minutesRead} min
        </div>
        {
          frontmatter.language && (
            <span class='flex items-center gap-1'>
              <Icon name='earth' class='size-5' />
              {frontmatter.language}
            </span>
          )
        }
        {
          !!frontmatter.tags?.length && (
            <span class='flex items-center gap-1'>
              <Icon name='hashtag' class='size-5' />
              {frontmatter.tags.map((tag: string, i: number) => (
                <div class="inline-flex">
                  <a
                    aria-label={`View more blogs with the tag ${tag}`}
                    class='hover:underline hover:underline-offset-4'
                    href={`/private/tags/${tag}`}
                  >
                    {tag}
                  </a>
                  {i < (frontmatter.tags?.length ?? 0) - 1 && '/'}
                </div>
              ))}
            </span>
          )
        }
      </div>

      <h1 class='mt-4 text-2xl font-medium sm:mb-2 sm:mt-6 sm:text-3xl'>
        {frontmatter.title}
      </h1>

      <div class='mt-3 italic'>
        <blockquote class='text-sm text-muted-foreground'><q>{frontmatter.description}</q></blockquote>
        
        {!frontmatter.draft && frontmatter.comment && <PageInfo comment class='mt-1' />}
      </div>
    </div>

    <div class='mt-4 w-1/2 border-t max-md:mx-auto sm:mt-6 sm:w-1/3'></div>
  </Fragment>

  <Content />

  <Fragment slot='bottom'>
    <Copyright data={{ ...frontmatter, heroImage: frontmatter.heroImage ? { src: resolvedHeroImage || frontmatter.heroImage.src } : undefined } as any} />
    <ArticleBottom collections={allPostsForBottom} id={slug || ''} class='mt-3 sm:mt-6' />
    
    {!frontmatter.draft && frontmatter.comment && <Comment class='mt-3 sm:mt-6' />}

    <div class="private-footer">
      <a href="/private" class="private-back-link">
        ← 返回私密文章列表
      </a>
    </div>
  </Fragment>
</PageLayout>

{config.integ.mediumZoom.enable && <MediumZoom />}

<script>
  const viewportHeight = window.innerHeight
  const threshold1 = viewportHeight / 9
  const threshold2 = (viewportHeight * 2) / 9
  const threshold3 = (viewportHeight * 3) / 9
  const image = document.getElementById('blurImage') as HTMLImageElement

  if (image) {
    window.addEventListener('scroll', () => {
      const scrollDistance = window.scrollY
      if (scrollDistance >= threshold3) {
        image.style.opacity = '0.15'
      } else if (scrollDistance >= threshold2) {
        image.style.opacity = '0.3'
      } else if (scrollDistance >= threshold1) {
        image.style.opacity = '0.45'
      }
    })
  }
</script>

<style>
  #blurImage {
    --un-blur: blur(24px);
    filter: var(--un-blur);
  }

  .private-badge-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .private-badge {
    display: inline-block;
    font-size: 0.75rem;
    padding: 0.2rem 0.625rem;
    border-radius: 2rem;
    background: hsl(var(--primary) / 0.1);
    color: hsl(var(--primary));
  }

  .private-lang {
    font-size: 0.75rem;
    padding: 0.2rem 0.625rem;
    border-radius: 2rem;
    background: hsl(var(--muted));
    color: hsl(var(--muted-foreground));
  }

  .private-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.5rem;
  }

  .private-tag-pill {
    font-size: 0.75rem;
    padding: 0.2rem 0.625rem;
    border-radius: 2rem;
    background: hsl(var(--muted));
    color: hsl(var(--muted-foreground));
    border: 1px solid hsl(var(--border));
    transition: color 0.2s, border-color 0.2s, background-color 0.2s;
    text-decoration: none;
  }

  .private-tag-pill:hover {
    color: hsl(var(--primary));
    border-color: hsl(var(--primary) / 0.3);
    background-color: hsl(var(--primary) / 0.05);
  }

  .private-footer {
    padding-top: 1.5rem;
    border-top: 1px solid hsl(var(--border) / 0.5);
    margin-top: 1.5rem;
  }

  .private-back-link {
    font-size: 0.875rem;
    color: hsl(var(--muted-foreground));
    text-decoration: none;
    transition: color 0.2s;
  }

  .private-back-link:hover {
    color: hsl(var(--primary));
  }
</style>

---
import { Image } from 'astro:assets'
import { Button, FormattedDate, Icon } from 'astro-pure/user'
import { cn } from 'astro-pure/utils'
import BaseLayout from '@/layouts/BaseLayout.astro'

// 禁止预渲染，确保每次请求都在服务端执行密码验证
export const prerender = false

import { isAuthenticated, getAuthToken, getPrivateSlug, PRIVATE_PASSWORD, PRIVATE_SECRET } from '@/utils/auth'

// ============ 处理 POST 请求（密码提交） ============
let error = ''
let authenticated = isAuthenticated(Astro.request)

if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData()
    const password = formData.get('password')?.toString() || ''

    if (password === PRIVATE_PASSWORD) {
      const token = getAuthToken(PRIVATE_SECRET)
      const isProd = import.meta.env.PROD
      const cookieFlags = [
        `private_auth=${token}`,
        'HttpOnly',
        'Path=/private',
        'SameSite=Strict',
        `Max-Age=${7 * 24 * 60 * 60}`, // 7 天
        isProd ? 'Secure' : ''
      ].filter(Boolean).join('; ')

      return new Response(null, {
        status: 302,
        headers: {
          'Location': '/private',
          'Set-Cookie': cookieFlags
        }
      })
    } else {
      error = '密码错误，请重试'
    }
  } catch {
    error = '请求处理失败，请重试'
  }
}

// ============ 已认证：加载私密文章列表 ============
interface PostFrontmatter {
  title: string
  description?: string
  publishDate: string
  tags?: string[]
  language?: string
  heroImage?: { src: string; color?: string }
}

interface PostModule {
  frontmatter: PostFrontmatter
  rawContent: () => string
}

let posts: { 
  slug: string; 
  title: string; 
  publishDate: string; 
  description: string; 
  tags: string[]; 
  language: string; 
  minutesRead: number;
  heroImage?: { src: string; color?: string; alt?: string };
  resolvedHeroImage?: ImageMetadata;
}[] = []

if (authenticated) {
  const postModules = import.meta.glob<PostModule>('/src/private-posts/**/[!_]*.md', { eager: true })
  const imageModules = import.meta.glob<{ default: ImageMetadata }>('/src/private-posts/**/*.{jpeg,jpg,png,gif,webp}')
  
  const entries = Object.entries(postModules)
  posts = await Promise.all(
    entries.map(async ([path, mod]) => {
      const slug = getPrivateSlug(path)
      
      // 解析题图
      let resolvedHeroImage: ImageMetadata | undefined
      const heroImage = mod.frontmatter.heroImage
      if (heroImage?.src) {
        let src = heroImage.src
        if (src.startsWith('./') || src.startsWith('../')) {
          const dir = path.split('/').slice(0, -1).join('/')
          if (src.startsWith('./')) src = src.slice(2)
          const absoluteImagePath = `${dir}/${src}`
          if (imageModules[absoluteImagePath]) {
            resolvedHeroImage = (await imageModules[absoluteImagePath]()).default
          }
        }
      }
      
      // 简易阅读时间计算（按每分钟 300 字计算）
      const rawContent = mod.rawContent ? mod.rawContent() : ''
      const wordCount = rawContent.replace(/<[^>]*>/g, '').replace(/\s+/g, '').length
      const minutesRead = Math.max(1, Math.ceil(wordCount / 300))

      return {
        slug,
        title: mod.frontmatter.title || slug,
        publishDate: mod.frontmatter.publishDate || '',
        description: mod.frontmatter.description || '',
        tags: mod.frontmatter.tags || [],
        language: mod.frontmatter.language || '',
        minutesRead,
        heroImage,
        resolvedHeroImage
      }
    })
  )
  posts.sort((a, b) => new Date(b.publishDate).getTime() - new Date(a.publishDate).getTime())
}

// 收集所有私密文章的标签并去重
const uniqueTags = [...new Set(posts.flatMap(p => p.tags))]
---

<BaseLayout meta={{ title: '私密空间' }}>
  <main class="mt-6 lg:mt-10">
    {authenticated ? (
      <>
        <div id='content-header' class='animate'>
          <h1 class='mb-6 mt-6 text-3xl font-medium sm:mt-10'>🔐 私密文章</h1>
        </div>
        
        {posts.length === 0 ? (
          <div class="empty-state">
            <p>还没有私密文章</p>
            <p class="empty-hint">在 <code>src/private-posts/</code> 目录下创建 <code>.md</code> 文件即可</p>
          </div>
        ) : (
          <div class='grid gap-y-16 sm:grid-cols-[3fr_1fr] sm:gap-x-8'>
            <section aria-label='Private posts list' class='animate' id='content'>
              <div class='mb-3 flex flex-col justify-between text-sm sm:mb-5 sm:flex-row'>
                <span class='text-muted-foreground'>
                  Showing {posts.length} private posts
                </span>
                <a aria-label='View all private posts by years' href='/private/archives' data-astro-prefetch>
                  View all posts by years →
                </a>
              </div>
              <ul class='flex flex-col gap-y-4 text-start'>
                {posts.map((post) => (
                  <li 
                    class="post-preview"
                    style={
                      post.heroImage?.color 
                        ? `--preview-highlight:color-mix(in srgb,${post.heroImage.color} 40%,hsl(var(--foreground)/var(--un-text-opacity,1))); --preview-highlight-bg:hsl(from ${post.heroImage.color} h s l/20%)` 
                        : undefined
                    }
                  >
                    <a
                      class={cn(
                        "block w-full relative group rounded-2xl border bg-background transition-colors ease-in-out px-5 py-2.5 hover:bg-muted hover:text-primary max-sm:px-4 sm:py-5",
                        post.resolvedHeroImage && "max-md:pt-24"
                      )}
                      href={`/private/${post.slug}`}
                      data-astro-prefetch
                    >
                      {post.resolvedHeroImage && (
                        <Image
                          alt={post.heroImage?.alt || post.title}
                          class='cover-image absolute end-0 top-0 z-0 h-2/3 w-full rounded-2xl object-cover opacity-50 transition-opacity duration-300 group-hover:opacity-70 md:h-full md:w-3/5'
                          loading='eager'
                          src={post.resolvedHeroImage}
                        />
                      )}
                      <div class="relative flex flex-col gap-1" style="z-index:1">
                        <FormattedDate class="min-w-[95px] text-xs" date={new Date(post.publishDate)} />
                        
                        <div class="flex justify-between flex-grow">
                          <div class="font-medium">{post.title}</div>
                          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="preview-redirect my-1 stroke-muted-foreground group-hover:stroke-primary"><line x1="5" y1="12" x2="19" y2="12" class="translate-x-4 scale-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1 group-hover:scale-x-100"></line><polyline points="12 5 19 12 12 19" class="translate-x-0 transition-all duration-300 ease-in-out group-hover:translate-x-1"></polyline></svg>
                        </div>
                        
                        {post.description && (
                          <p class={cn(
                            "line-clamp-2 text-sm text-muted-foreground sm:line-clamp-3",
                            post.resolvedHeroImage && "sm:me-24"
                          )}>
                            {post.description}
                          </p>
                        )}
                        <div class="py-2 flex items-center gap-2 text-sm italic leading-4 text-muted-foreground">
                          <span class="flex items-center gap-1">
                            <Icon name="time" class="size-4" />
                            {post.minutesRead} min
                          </span>
                          {post.language && (
                            <span class="flex items-center gap-1">
                              <Icon name="earth" class="size-4" />
                              {post.language}
                            </span>
                          )}
                        </div>
                        {post.tags.length > 0 && (
                          <object title="Tags" aria-label="Tags" aria-labelledby="Tags">
                            <ul class="tag-list mt-1 flex gap-2">
                              {post.tags.map((tag) => (
                                <li>
                                  <Button as="a" title={tag} href={`/private/tags/${tag}`} variant="pill" />
                                </li>
                              ))}
                            </ul>
                          </object>
                        )}
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </section>

            {!!uniqueTags.length && (
              <aside class='animate' id='sidebar'>
                <h2 class='mb-4 flex items-center text-lg font-medium'>
                  <Icon name='tag-2' class='me-2' />
                  Tags
                </h2>
                <ul class='text-bgColor flex flex-wrap gap-2'>
                  {uniqueTags.map((tag) => (
                    <li>
                      <Button title={tag} href={`/private/tags/${tag}`} variant='pill' as='a' />
                    </li>
                  ))}
                </ul>
                <span class='mt-4 block sm:text-end'>
                  <a aria-label='View all blog categories' href='/private/tags' data-astro-prefetch>
                    View all →
                  </a>
                </span>
              </aside>
            )}
          </div>
        )}
      </>
    ) : (
      <div class="auth-wrapper">
        <div class="auth-card">
          <div class="auth-glow"></div>
          <div class="lock-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/><circle cx="12" cy="16" r="1"/></svg>
          </div>
          <h1 class="auth-title">私密空间</h1>
          <p class="auth-subtitle">请输入访问密码以查看私密内容</p>

          {error && (
            <div class="auth-error">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
              {error}
            </div>
          )}

          <form method="POST" class="auth-form">
            <div class="input-group">
              <input
                type="password"
                name="password"
                placeholder="输入密码..."
                required
                autofocus
                autocomplete="current-password"
              />
            </div>
            <button type="submit" class="auth-submit">
              验证身份
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </form>

          <p class="auth-hint">认证状态将保持 7 天</p>
        </div>
      </div>
    )}
  </main>
</BaseLayout>

<style>
  .post-preview {
    --preview-highlight-final: var(--preview-highlight, hsl(var(--primary) / var(--un-text-opacity, 1)));
  }
  .post-preview:hover {
    & > a,
    & .private-tag-pill {
      background-color: var( --preview-highlight-bg, hsl(var(--muted) / var(--un-bg-opacity, 1))) !important;
    }
    & > a,
    & .private-tag-pill:hover {
      color: var(--preview-highlight-final) !important;
    }
    & > a .preview-redirect {
      stroke: var(--preview-highlight-final) !important;
    }
  }

  .cover-image {
    -webkit-mask-image: -webkit-linear-gradient(left, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 1) 100%);
    -webkit-mask-image: linear-gradient(to right, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 1) 100%);
    mask-image: linear-gradient(to right, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 1) 100%);
  }

  @media (max-width: 768px) {
    .cover-image {
      -webkit-mask-image: -webkit-linear-gradient(bottom, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 1) 100%);
      -webkit-mask-image: linear-gradient(to top, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 1) 100%);
      mask-image: linear-gradient(to top, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 1) 100%);
    }
  }

  /* ===== 密码输入界面 ===== */
  .auth-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 55vh;
  }

  .auth-card {
    position: relative;
    width: 100%;
    max-width: 420px;
    padding: 2.5rem;
    border-radius: 1.25rem;
    border: 1px solid hsl(var(--border) / 0.5);
    background: hsl(var(--background) / 0.8);
    backdrop-filter: blur(16px);
    text-align: center;
    overflow: hidden;
  }

  .auth-glow {
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 200%;
    height: 200%;
    background: radial-gradient(ellipse at center, hsl(var(--primary) / 0.06) 0%, transparent 60%);
    pointer-events: none;
  }

  .lock-icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: hsl(var(--muted));
    color: hsl(var(--primary));
    margin-bottom: 1.25rem;
  }

  .auth-title {
    position: relative;
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .auth-subtitle {
    position: relative;
    font-size: 0.875rem;
    color: hsl(var(--muted-foreground));
    margin-bottom: 1.5rem;
  }

  .auth-error {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.625rem 1rem;
    margin-bottom: 1rem;
    border-radius: 0.75rem;
    font-size: 0.8125rem;
    color: #f87171;
    background: rgba(248, 113, 113, 0.08);
    border: 1px solid rgba(248, 113, 113, 0.2);
  }

  .auth-form {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .input-group input {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    border: 1px solid hsl(var(--border));
    background: hsl(var(--muted) / 0.5);
    color: hsl(var(--foreground));
    font-size: 0.9375rem;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }

  .input-group input:focus {
    border-color: hsl(var(--primary));
    box-shadow: 0 0 0 3px hsl(var(--primary) / 0.1);
  }

  .input-group input::placeholder {
    color: hsl(var(--muted-foreground) / 0.5);
  }

  .auth-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    border-radius: 0.75rem;
    border: none;
    background: hsl(var(--primary));
    color: hsl(var(--background));
    font-size: 0.9375rem;
    font-weight: 500;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
  }

  .auth-submit:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .auth-submit:active {
    transform: translateY(0);
  }

  .auth-hint {
    position: relative;
    font-size: 0.75rem;
    color: hsl(var(--muted-foreground) / 0.5);
    margin-top: 1rem;
  }

  /* ===== 文章列表界面 ===== */
  .private-container {
    margin: 0 auto;
  }

  .private-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.25rem;
  }

  .private-title {
    font-size: 1.75rem;
    font-weight: 600;
  }

  .logout-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1rem;
    border-radius: 0.625rem;
    font-size: 0.8125rem;
    color: hsl(var(--muted-foreground));
    border: 1px solid hsl(var(--border));
    background: hsl(var(--muted) / 0.5);
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .logout-btn:hover {
    color: #f87171;
    border-color: rgba(248, 113, 113, 0.3);
    background: rgba(248, 113, 113, 0.06);
  }

  .private-subtitle {
    font-size: 0.875rem;
    color: hsl(var(--muted-foreground));
    margin-bottom: 2rem;
  }

  .empty-state {
    text-align: center;
    padding: 3rem 1rem;
    color: hsl(var(--muted-foreground));
  }

  .empty-hint {
    font-size: 0.8125rem;
    margin-top: 0.5rem;
    opacity: 0.6;
  }

  .empty-hint code {
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    background: hsl(var(--muted));
    font-size: 0.75rem;
  }

  /* ===== 响应式 ===== */
  @media (max-width: 640px) {
    .auth-card {
      margin: 0 1rem;
      padding: 2rem 1.5rem;
    }
  }
</style>

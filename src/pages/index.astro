    {/*调用 Quote 组件（英文语录api）*/}
    {/* <Quote class='mt-12' /> */}

    {/* Hitokoto 中文随机语录 */}
    <div class='not-prose mt-12 flex justify-center'>
      <div class='flex items-center gap-x-3 rounded-full border bg-background px-4 py-2 text-sm shadow-sm transition-shadow hover:shadow-md'>
        <span class='size-2 rounded-full bg-green-400'></span>
        <p id='hitokoto-text' class='font-medium text-muted-foreground'>正在拉取数据...</p>
      </div>
    </div>

    <script is:inline>
      // 轻量级原生 Fetch 请求
      fetch('https://v1.hitokoto.cn/?c=d&c=i&c=k&c=f&c=a&c=b')
        .then(response => response.json())
        .then(data => {
          const hitokotoElement = document.getElementById('hitokoto-text');
          if (hitokotoElement) {
            hitokotoElement.innerText = data.hitokoto;
          }
        })
        .catch(error => {
          // 如果网络异常或被广告拦截插件误杀，静默降级为本地预设文本
          console.error('Hitokoto fetch failed:', error);
          const hitokotoElement = document.getElementById('hitokoto-text');
          if (hitokotoElement) {
            hitokotoElement.innerText = '去冗除杂，保持敏锐。'; 
          }
        });
    </script>

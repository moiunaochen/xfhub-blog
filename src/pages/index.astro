    <div id='content' class='animate flex flex-col gap-y-10 md:w-4/5 lg:w-5/6'>
      {/* Modified: 替换 About 段落为 x枫. 的个人简介 */}
      <Section title='About'>
        {/* Modified: Security Enthusiast 改为 Genius trader 并加中划线 */}
        <p class='text-muted-foreground'>Developer / <del>Genius trader</del></p>
        {/* Modified: 替换为详细的个人自我介绍 */}
